{
  "expo": {
    "name": "Fitfiles",
    "slug": "fitfiles",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "fitfiles",
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.banditinnovations.fitfiles"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1220"
      },
      "package": "com.banditinnovations.fitfiles"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
