{
  "expo": {
    "name": "FitLinks",
    "slug": "fitlinks",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/fitlinks_logo_navy.png",
    "userInterfaceStyle": "light",
    "scheme": "fitlinks",
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "icon": "./assets/fitlinks_logo_navy.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.banditinnovations.fitlinks",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
