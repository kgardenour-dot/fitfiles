        "com.apple.security.application-groups": [
          "group.com.banditinnovations.fitlinks"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/fitlinks_logo_navy.png",
        "backgroundColor": "#0B1220"
      },
      "package": "com.banditinnovations.fitlinks"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-share-intent",
