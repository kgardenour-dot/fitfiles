{
  "expo": {
    "name": "FitLinks",
    "slug": "fitlinks",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/fitlinks_logo_navy.png",
    "userInterfaceStyle": "light",
    "scheme": "fitlinks",
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "buildNumber": "15",
      "icon": "./assets/fitlinks_logo_navy.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.banditinnovations.fitlinks",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.banditinnovations.fitlinks"
        ]
      }
    },
    "android": {
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/fitlinks_logo_navy.png",
        "backgroundColor": "#0B1220"
      },
      "package": "com.banditinnovations.fitlinks"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-share-intent",
        {
          "iosAppGroupIdentifier": "group.com.banditinnovations.fitlinks"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc276007-b5c7-41f6-81d9-2abc9a9e5427"
      }
    },
    "owner": "kgardenour-dot"
  }
}