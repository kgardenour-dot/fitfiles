# Required for auth and data. Local dev: copy to .env (gitignored).
# TestFlight / Play / App Store: set these on expo.dev → Project → Environment variables
# for the same environment as your store build (production when using beta/production profile),
# or: eas env:create --name EXPO_PUBLIC_SUPABASE_URL --value "https://YOUR_PROJECT.supabase.co" --environment production
# Rebuild after changing; EXPO_PUBLIC_* are baked in at bundle time.
EXPO_PUBLIC_SUPABASE_URL=
# Legacy anon JWT or new publishable key (sb_publishable_…)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_BETA_DISABLE_PAYWALL=false

# RevenueCat (public SDK keys from Project settings → API keys)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
# Entitlement identifier from RevenueCat → Entitlements (default: pro)
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_PRO=pro
